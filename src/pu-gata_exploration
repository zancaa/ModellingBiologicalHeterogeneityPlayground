# To plot using CairoMakie
# Function to extract all branches from the bifurcationdiagram
function collect_branches(node, acc = [])
    push!(acc, node.γ)
    for child in node.child
        collect_branches(child, acc)
    end
    return acc
end

all_branches = collect_branches(bif_dia)

# Plot bifurcation diagram (to check it matches Duff et al 2012 - it does)
fig1 = Figure(size = (800, 500))
ax1 = Axis(fig1[1, 1],
    xlabel = "a",
    ylabel = "G"
)

col_stable   = :royalblue
col_unstable = :tomato

# Plotting whole branches is a bit of a faff, just plot calculated points for now
function plot_branch!(ax, br, color_s, color_u)
    a = getproperty.(br.branch, :param)      # parameter values (in this case, a)
    G = getproperty.(br.branch, :x)          # values for G (or whatever is being calculated)
    stable = br.stable                       # stability of point

	for i in 1:length(a)
		col = stable[i] ? color_s : color_u
		scatter!(ax, a[i], G[i], color = col, markersize=10)
	end

end

for br in all_branches
    plot_branch!(ax1, br, col_stable, col_unstable)
end

