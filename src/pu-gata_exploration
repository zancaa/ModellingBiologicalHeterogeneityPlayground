# Do some stuff to plot streamplots (following Makie documentation)
struct Duff{T}
    a::T
    b::T
	θ1::T
    θ2::T
	n::T
	m::T
	k::T
end

P = Duff(1.0, 1.0, 0.5, 0.07, 4.0, 1.0, 1.0)

f(x, P::Duff) = Point2f(
    (P.a*x[1]^P.n/(P.θ1^P.n + x[1]^P.n) + P.b*P.θ2^P.m/(P.θ2^P.m + x[1]^P.m*x[2]^P.m) - P.k*x[1]),
    (P.a*x[2]^P.n/(P.θ1^P.n + x[2]^P.n) + P.b*P.θ2^P.m/(P.θ2^P.m + x[1]^P.m*x[2]^P.m) - P.k*x[2])
)

f(x) = f(x, P)

streamplot!(ax2, f, 0.0:0.02:2.0, 0.0:0.02:2.0, colormap = :magma)

# Plot attractors on top
