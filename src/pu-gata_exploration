using Catalyst, OrdinaryDiffEqDefault, CairoMakie, BifurcationKit, DynamicalSystems, OrdinaryDiffEqTsit5

# Function for the cross-inhibition terms
cross_inhibition(G, P, b, θb, m) = b * (θb^m)/(θb^m + G^m*P^m)

##################### Full model - not yet explored ###########################
# Create model
rn = @reaction_network begin
	hill(G, a1, θa1, n), ∅ --> G
	hill(P, a2, θa2, n), ∅ --> P
	cross_inhibition(G, P, b1, θb1, m), ∅ --> G
	cross_inhibition(G, P, b2, θb2, m), ∅ --> P
	k1, G --> ∅
	k2, P --> ∅
end

# Set initial conditions, time span and parameter values
u0 = [:G => 0.8, :P => 0.4]
tspan = (0.0, 50.0)
ps = [:a1 => 1.0, :θa1 => 0.5, :n => 4, :a2 => 1.0, :θa2 => 0.5, :b1 => 1, :θb1 => 0.07,
	 :b2 => 1, :θb2 => 0.07, :m => 1, :k1 => 1, :k2 => 1]

# Sample solutions
oprob = ODEProblem(rn, u0, tspan, ps)
sol = solve(oprob)

